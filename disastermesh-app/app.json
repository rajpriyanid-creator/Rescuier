{
  "expo": {
    "name": "DisasterMesh",
    "slug": "resuier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "scheme": "disastermesh",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icons/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.disastermesh.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "DisasterMesh needs location for emergency response.",
        "NSLocationAlwaysUsageDescription": "DisasterMesh needs background location during active disasters.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "DisasterMesh needs location for emergency response.",
        "NSMotionUsageDescription": "DisasterMesh uses motion sensors to detect earthquakes.",
        "NSCameraUsageDescription": "DisasterMesh needs camera to capture disaster photos.",
        "NSMicrophoneUsageDescription": "DisasterMesh uses microphone for voice vault messages.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.disastermesh.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "DisasterMesh needs location for emergency response.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-sensors",
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/notification-icon.png",
          "color": "#dc2626",
          "defaultChannel": "disaster"
        }
      ],
      "expo-background-fetch",
      "expo-task-manager",
      "expo-local-authentication",
      "expo-secure-store",
      "expo-sqlite",
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "DisasterMesh needs camera to capture disaster photos."
        }
      ],
      "expo-av",
      "expo-file-system"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "*": {},
        "projectId": "b1559008-6559-4ae4-9460-5f04dbf264d5"
      }
    },
    "owner": "rajpriyan_s"
  }
}
